// ════════════════════════════════════════════════════════
//  BANANA RADIATION RUNNER — Component Styles
// ════════════════════════════════════════════════════════

:host {
  display: block;
  background: #0a0a1a;
  font-family: 'Segoe UI', Arial, sans-serif;
  color: #e8eaf0;
}

// ── TOKENS ──────────────────────────────────────────────
$bg:       #0a0a1a;
$surface:  #0d0d20;
$surface2: #16182a;
$border:   #2a2a50;
$accent:   #a29bfe;
$gold:     #f9ca24;
$teal:     #00b894;
$red:      #e74c3c;
$blue:     #74b9ff;
$muted:    #636e72;
$radius:   14px;

// ── ROOT ─────────────────────────────────────────────────
.runner-root {
  max-width: 940px;
  margin: 0 auto;
  padding: 24px 20px 48px;
}

// ═══ GAME WRAPPER ═══════════════════════════════════════
.game-wrapper {
  position: relative;
  width: 900px;
  border-radius: $radius $radius 0 0;
  overflow: hidden;
}

.game-canvas {
  display: block;
  width: 900px;
  height: 379px;
  cursor: pointer;
  image-rendering: pixelated;
  image-rendering: crisp-edges;
  image-rendering: -moz-crisp-edges;
}

.flash-overlay {
  position: absolute;
  inset: 0;
  pointer-events: none;
  opacity: 0;
  transition: opacity 0.12s;
  border-radius: $radius $radius 0 0;
  z-index: 5;
}

// ── OVERLAYS ─────────────────────────────────────────────
.overlay {
  position: absolute;
  inset: 0;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  z-index: 10;
  transition: opacity 0.35s;

  &.hidden { opacity: 0; pointer-events: none; }
}

.loading-overlay {
  background: rgba(10, 10, 26, 0.97);
}

.start-overlay {
  background: linear-gradient(160deg, rgba(15,20,60,0.95) 0%, rgba(10,10,26,0.97) 100%);
}

.death-overlay {
  background: linear-gradient(160deg, rgba(60,5,5,0.97) 0%, rgba(26,5,5,0.98) 100%);
}

.game-title {
  font-size: 2.6em;
  font-weight: 900;
  letter-spacing: 3px;
  background: linear-gradient(90deg, $gold, #f0932b, #e17055, $accent);
  -webkit-background-clip: text;
  -webkit-text-fill-color: transparent;
  margin-bottom: 6px;
  text-align: center;
}

.game-sub {
  color: $accent;
  font-style: italic;
  font-size: 0.95em;
  margin-bottom: 20px;
}

// Fact row on start screen
.fact-row {
  display: flex;
  gap: 8px;
  margin-bottom: 22px;
  flex-wrap: wrap;
  justify-content: center;
}

.fact-card {
  background: rgba(255,255,255,0.06);
  border: 1px solid rgba(255,255,255,0.12);
  border-radius: 10px;
  padding: 8px 12px;
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 2px;
  font-size: 0.78em;
  color: #b2bec3;
  min-width: 100px;

  .fact-icon { font-size: 1.5em; }
  .fact-dose { font-weight: 700; font-size: 0.9em; }
}

// Buttons
.big-btn {
  padding: 13px 48px;
  background: linear-gradient(135deg, #6c5ce7, $accent);
  color: #fff;
  border: none;
  border-radius: 50px;
  font-size: 1.2em;
  font-weight: 700;
  cursor: pointer;
  letter-spacing: 2px;
  text-transform: uppercase;
  box-shadow: 0 8px 30px rgba(108,92,231,0.5);
  transition: transform 0.2s;

  &:hover { transform: translateY(-3px); }
}

.ctrl-chips {
  display: flex;
  gap: 10px;
  margin-top: 14px;
  flex-wrap: wrap;
  justify-content: center;
}

.ctrl-chip {
  background: rgba(255,255,255,0.07);
  border: 1px solid rgba(255,255,255,0.14);
  border-radius: 8px;
  padding: 5px 12px;
  font-size: 0.78em;
  color: #dfe6e9;

  kbd {
    background: rgba(255,255,255,0.18);
    border-radius: 4px;
    padding: 1px 5px;
    font-size: 0.9em;
    font-family: monospace;
    margin-right: 4px;
  }
}

// Loading bar
.load-track {
  width: 280px;
  height: 6px;
  background: rgba(255,255,255,0.08);
  border-radius: 3px;
  overflow: hidden;
  margin: 14px 0;
}

.load-fill {
  height: 100%;
  background: linear-gradient(90deg, #6c5ce7, $accent, $gold);
  border-radius: 3px;
  transition: width 0.2s ease;
}

.load-text { color: $accent; font-size: 0.82em; }

// Death overlay
.death-title {
  font-size: 2.4em;
  font-weight: 900;
  color: $red;
  text-shadow: 0 0 30px rgba(231,76,60,0.8);
  margin-bottom: 6px;
}

.death-sub { color: #e17055; font-size: 0.9em; margin-bottom: 18px; }

.death-stats {
  background: rgba(255,255,255,0.05);
  border-radius: 12px;
  padding: 14px 22px;
  margin-bottom: 18px;
  min-width: 320px;
  border: 1px solid rgba(231,76,60,0.2);
}

.stat-row {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 4px 0;
  font-size: 0.84em;
  color: #b2bec3;
  border-bottom: 1px solid rgba(255,255,255,0.05);

  &:last-child { border: none; }

  strong { font-weight: 700; color: #fff; }
  strong.red { color: $red; }
}

.restart-btn {
  padding: 11px 34px;
  background: linear-gradient(135deg, $red, #c0392b);
  color: #fff;
  border: none;
  border-radius: 50px;
  font-size: 1.05em;
  font-weight: 700;
  cursor: pointer;
  box-shadow: 0 6px 20px rgba(231,76,60,0.4);
  transition: transform 0.2s;

  &:hover { transform: translateY(-2px); }
}

// ═══ HUD ════════════════════════════════════════════════
.hud {
  display: flex;
  align-items: center;
  gap: 14px;
  background: $surface;
  padding: 10px 18px;
  border-radius: 0 0 $radius $radius;
  border-top: 2px solid $border;
}

// Gauge
.gauge-wrap {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 3px;
  min-width: 54px;
}

.gauge-lbl {
  color: $accent;
  font-size: 0.62em;
  font-weight: 700;
  letter-spacing: 1px;
  text-transform: uppercase;
}

.gauge-outer {
  width: 38px;
  height: 110px;
  background: rgba(255,255,255,0.08);
  border-radius: 19px;
  border: 2px solid #3a3a70;
  overflow: hidden;
  display: flex;
  flex-direction: column;
  justify-content: flex-end;
  position: relative;

  &::before {
    content: '';
    position: absolute;
    inset: 0;
    border-radius: 17px;
    pointer-events: none;
    background: repeating-linear-gradient(
      to bottom,
      transparent 0, transparent 21px,
      rgba(255,255,255,0.12) 21px, rgba(255,255,255,0.12) 22px
    );
  }
}

.gauge-fill {
  width: 100%;
  background: linear-gradient(to top, $teal 0%, #fdcb6e 45%, #e17055 75%, $red 100%);
  border-radius: 17px;
  transition: height 0.35s ease;
}

.gauge-icon { font-size: 1.5em; line-height: 1; }
.gauge-pct  { color: #fff; font-size: 0.68em; font-weight: 700; }

// Score area
.hud-info { flex: 1; display: flex; flex-direction: column; gap: 6px; }

.score-row { display: flex; gap: 18px; align-items: baseline; }

.score-block {
  display: flex;
  flex-direction: column;
}

.score-lbl { color: $muted; font-size: 0.72em; text-transform: uppercase; letter-spacing: 1px; }

.score-val {
  font-size: 1.8em;
  font-weight: 900;
  background: linear-gradient(90deg, $gold, #f0932b);
  -webkit-background-clip: text;
  -webkit-text-fill-color: transparent;

  &.blue   { background: none; -webkit-text-fill-color: $blue; }
  &.yellow { background: none; -webkit-text-fill-color: $gold; }
}

// Status badge
.status-badge {
  padding: 5px 14px;
  border-radius: 20px;
  font-size: 0.82em;
  font-weight: 700;
  transition: all 0.5s;
  white-space: nowrap;
  width: fit-content;

  &.healthy  { background: rgba(39,174,96,0.2);   color: #2ecc71;  border: 1px solid #27ae60; }
  &.confused { background: rgba(243,156,18,0.2);  color: #f39c12;  border: 1px solid #e67e22; }
  &.sick     { background: rgba(231,76,60,0.2);   color: $red;     border: 1px solid #c0392b; }
  &.critical { background: rgba(142,68,173,0.3);  color: #e056fd;  border: 1px solid #8e44ad; }
}

// Event log
.event-log {
  width: 200px;
  display: flex;
  flex-direction: column;
  gap: 4px;
  overflow: hidden;
  height: 80px;
}

.event-item {
  font-size: 0.68em;
  padding: 3px 8px;
  border-radius: 8px;
  border-left: 3px solid;
  animation: slideIn 0.3s ease;
  white-space: nowrap;
  overflow: hidden;
  text-overflow: ellipsis;

  &.ev-hit   { background: rgba(214,48,49,0.2);  border-color: #d63031; color: #fab1a0; }
  &.ev-jump  { background: rgba(0,184,148,0.2);  border-color: $teal;   color: #55efc4; }
  &.ev-spawn { background: rgba(249,202,36,0.2); border-color: $gold;   color: #ffeaa7; }
}

@keyframes slideIn {
  from { opacity: 0; transform: translateX(20px); }
  to   { opacity: 1; transform: translateX(0); }
}

// Controls hint
.ctrl-hint {
  display: flex;
  flex-direction: column;
  gap: 4px;
  min-width: 100px;
}

.key-badge {
  display: inline-flex;
  align-items: center;
  gap: 6px;
  background: rgba(255,255,255,0.07);
  border: 1px solid rgba(255,255,255,0.15);
  border-radius: 8px;
  padding: 4px 10px;
  font-size: 0.72em;
  color: #b2bec3;

  kbd {
    background: rgba(255,255,255,0.15);
    border-radius: 4px;
    padding: 1px 6px;
    font-size: 0.9em;
    font-family: monospace;
    color: #fff;
  }
}

// ═══ GUIDE SECTION ══════════════════════════════════════
.guide-section {
  margin-top: 36px;
  padding: 0 4px;
}

.guide-header {
  display: flex;
  justify-content: space-between;
  align-items: flex-start;
  gap: 20px;
  margin-bottom: 24px;
  flex-wrap: wrap;
}

.guide-title {
  font-size: 1.5em;
  font-weight: 800;
  color: #fff;
  margin-bottom: 4px;
}

.guide-sub {
  color: $muted;
  font-size: 0.88em;
  max-width: 480px;
  line-height: 1.6;

  strong { color: #fff; }
}

// Filter chips
.filter-chips { display: flex; gap: 6px; flex-wrap: wrap; margin-top: 4px; }

.filter-chip {
  padding: 5px 14px;
  border-radius: 20px;
  border: 1px solid $border;
  background: rgba(255,255,255,0.05);
  color: $muted;
  font-size: 0.78em;
  font-weight: 600;
  cursor: pointer;
  text-transform: capitalize;
  transition: all 0.2s;

  &:hover { border-color: $accent; color: $accent; }
  &.active { background: rgba(162,155,254,0.18); border-color: $accent; color: $accent; }
}

// Obstacle legend
.obstacle-legend {
  background: $surface;
  border: 1px solid $border;
  border-radius: 12px;
  padding: 16px 20px;
  margin-bottom: 24px;
}

.legend-title {
  font-size: 0.72em;
  font-weight: 700;
  text-transform: uppercase;
  letter-spacing: 1px;
  color: $muted;
  margin-bottom: 12px;
}

.legend-row {
  display: flex;
  flex-wrap: wrap;
  gap: 12px;
}

.legend-item {
  display: flex;
  align-items: center;
  gap: 8px;
  flex: 1;
  min-width: 130px;
}

.leg-emoji { font-size: 1.4em; }

.leg-info {
  display: flex;
  flex-direction: column;
  font-size: 0.78em;

  strong { color: #fff; font-weight: 700; }
  span   { font-weight: 600; font-size: 0.9em; }
}

.leg-bar-wrap {
  flex: 1;
  height: 5px;
  background: rgba(255,255,255,0.08);
  border-radius: 3px;
  overflow: hidden;
}

.leg-bar {
  height: 100%;
  border-radius: 3px;
  transition: width 0.3s;
  opacity: 0.8;
}

// Guide grid
.guide-grid {
  display: grid;
  grid-template-columns: repeat(auto-fill, minmax(280px, 1fr));
  gap: 16px;
  margin-bottom: 28px;
}

.guide-card {
  background: $surface;
  border: 1px solid $border;
  border-radius: 12px;
  padding: 16px;
  transition: transform 0.2s, box-shadow 0.2s;

  &:hover { transform: translateY(-2px); box-shadow: 0 8px 24px rgba(0,0,0,0.3); }

  &.cat-safe     { border-color: rgba(0,184,148,0.3); }
  &.cat-low      { border-color: rgba(116,185,255,0.3); }
  &.cat-medium   { border-color: rgba(253,203,110,0.3); }
  &.cat-high     { border-color: rgba(231,76,60,0.3); }
  &.cat-critical { border-color: rgba(142,68,173,0.4); box-shadow: 0 0 12px rgba(142,68,173,0.15); }
}

.guide-card-head {
  display: flex;
  align-items: flex-start;
  gap: 10px;
  margin-bottom: 10px;
}

.guide-emoji { font-size: 1.8em; line-height: 1; flex-shrink: 0; }

.guide-meta {
  flex: 1;
  display: flex;
  flex-direction: column;
  gap: 2px;
}

.guide-source { font-size: 0.9em; color: #fff; font-weight: 700; }

.guide-dose {
  font-size: 0.82em;
  font-weight: 700;

  &.dose-safe     { color: $teal; }
  &.dose-low      { color: $blue; }
  &.dose-medium   { color: $gold; }
  &.dose-high     { color: $red; }
  &.dose-critical { color: #e056fd; }
}

.cat-badge {
  font-size: 0.62em;
  font-weight: 700;
  padding: 2px 8px;
  border-radius: 10px;
  text-transform: uppercase;
  letter-spacing: 0.5px;
  white-space: nowrap;
  flex-shrink: 0;

  &.badge-safe     { background: rgba(0,184,148,0.2);   color: $teal;   }
  &.badge-low      { background: rgba(116,185,255,0.2); color: $blue;   }
  &.badge-medium   { background: rgba(249,202,36,0.2);  color: $gold;   }
  &.badge-high     { background: rgba(231,76,60,0.2);   color: $red;    }
  &.badge-critical { background: rgba(142,68,173,0.2);  color: #e056fd; }
}

// Dose bar inside card
.dose-bar-track {
  height: 5px;
  background: rgba(255,255,255,0.07);
  border-radius: 3px;
  overflow: hidden;
  margin-bottom: 10px;
}

.dose-bar-fill {
  height: 100%;
  border-radius: 3px;
  min-width: 3px;
  transition: width 0.4s;

  &.fill-safe     { background: $teal; }
  &.fill-low      { background: $blue; }
  &.fill-medium   { background: $gold; }
  &.fill-high     { background: $red; }
  &.fill-critical { background: #e056fd; }
}

.guide-desc { font-size: 0.8em; color: $muted; line-height: 1.6; }

// Dose scale
.dose-scale {
  background: $surface;
  border: 1px solid $border;
  border-radius: 12px;
  padding: 16px 20px;
  margin-bottom: 24px;
}

.scale-title { font-size: 0.72em; font-weight: 700; color: $muted; text-transform: uppercase; letter-spacing: 1px; margin-bottom: 10px; }

.scale-bar {
  display: flex;
  height: 12px;
  border-radius: 6px;
  overflow: hidden;
  margin-bottom: 6px;
}

.scale-fill {
  &.safe     { background: $teal; }
  &.low      { background: $blue; }
  &.medium   { background: $gold; }
  &.high     { background: $red; }
  &.critical { background: #e056fd; }
}

.scale-labels {
  display: flex;
  justify-content: space-between;
  font-size: 0.68em;
  color: $muted;
  margin-bottom: 8px;
}

.scale-legend { display: flex; gap: 12px; }

.sleg {
  font-size: 0.72em;
  font-weight: 700;
  text-transform: capitalize;
  padding: 2px 8px;
  border-radius: 8px;

  &.sleg-safe     { background: rgba(0,184,148,0.15);   color: $teal;   }
  &.sleg-low      { background: rgba(116,185,255,0.15); color: $blue;   }
  &.sleg-medium   { background: rgba(249,202,36,0.15);  color: $gold;   }
  &.sleg-high     { background: rgba(231,76,60,0.15);   color: $red;    }
  &.sleg-critical { background: rgba(142,68,173,0.15);  color: #e056fd; }
}

// Key facts strip
.key-facts {
  display: flex;
  align-items: center;
  background: linear-gradient(135deg, rgba(108,92,231,0.12), rgba(249,202,36,0.06));
  border: 1px solid rgba(162,155,254,0.2);
  border-radius: 12px;
  padding: 20px 28px;
  gap: 0;
  flex-wrap: wrap;
}

.kf-item {
  flex: 1;
  min-width: 160px;
  display: flex;
  flex-direction: column;
  align-items: center;
  text-align: center;
  gap: 2px;
  padding: 8px;
}

.kf-num {
  font-size: 1.5em;
  font-weight: 900;
  background: linear-gradient(90deg, $gold, $accent);
  -webkit-background-clip: text;
  -webkit-text-fill-color: transparent;
  line-height: 1.1;
}

.kf-unit  { font-size: 0.72em; color: $accent; font-weight: 600; }
.kf-label { font-size: 0.75em; color: $muted; line-height: 1.4; }

.kf-divider {
  width: 1px;
  height: 50px;
  background: $border;
  flex-shrink: 0;
}

// ── RESPONSIVE ───────────────────────────────────────────
@media (max-width: 940px) {
  .game-wrapper, .game-canvas, .hud { width: 100%; }
  .game-canvas { height: auto; aspect-ratio: 900 / 379; }
  .guide-grid  { grid-template-columns: 1fr; }
  .key-facts   { flex-direction: column; align-items: stretch; }
  .kf-divider  { width: 100%; height: 1px; }
  .fact-row    { gap: 6px; }
}
